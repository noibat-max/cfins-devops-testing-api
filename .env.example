# cfins-devops-testing-api — local environment
# Copy to `.env` (gitignored) and fill in. run-local.sh loads this file.
# In prod (ECS) these come from the task definition / Secrets Manager, NOT a file.

# --- AWS ---------------------------------------------------------------------
# Local dev uses a named profile; boto3's default credential chain picks it up.
# On ECS this is unset and the task role is used instead — same app code.
AWS_PROFILE=cfins-local
AWS_REGION=us-east-1

# --- DynamoDB ----------------------------------------------------------------
WORKBENCH_TABLE=cfins-qaworkbench

# --- Auth / JWT --------------------------------------------------------------
# Signing key for locally-minted HS256 tokens. Generate a random one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Keep it out of git; in prod load from Secrets Manager.
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ISSUER=cfins-qaworkbench
JWT_TTL_HOURS=8

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed UI origins (the Vite dev server).
CORS_ORIGINS=http://localhost:5173

# --- Cognito (SSO) -----------------------------------------------------------
# Leave blank to disable SSO (local login still works). No AWS credentials are
# needed for SSO login — tokens are validated via the public JWKS endpoint, and
# identity is fetched from the Managed-login /oauth2/userInfo endpoint.
COGNITO_USER_POOL_ID=us-east-1_y7VZjMb6N
COGNITO_CLIENT_ID=25ihduhnl3v8o4f4uuqjh41jkl
COGNITO_DOMAIN=https://us-east-1y7vzjmb6n.auth.us-east-1.amazoncognito.com
