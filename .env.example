# cfins-devops-testing-api — local environment
# Copy to `.env` (gitignored) and fill in. run-local.sh loads this file.
# In prod (ECS) these come from the task definition / Secrets Manager, NOT a file.

# --- Environment -------------------------------------------------------------
# Which deployed environment this API is (dev/qa/sat/prod). Stamped onto PATs so
# a token minted here is rejected elsewhere. "local" for a dev machine.
ENVIRONMENT=local

# --- Diagnostic logging ------------------------------------------------------
# LOG_LEVEL: verbosity of the app's cfins.* loggers (DEBUG|INFO|WARNING|ERROR).
#   Set DEBUG to trace an issue; every line carries a correlation id + user.
# LOG_FORMAT: "json" (default; one object per line, queryable in CloudWatch Logs
#   Insights by correlation_id/user) or "plain" (human-readable — use it locally).
LOG_LEVEL=INFO
LOG_FORMAT=plain

# --- AWS ---------------------------------------------------------------------
# Local dev uses a named profile; boto3's default credential chain picks it up.
# On ECS this is unset and the task role is used instead — same app code.
AWS_PROFILE=cfins-local
AWS_REGION=us-east-1

# --- DynamoDB ----------------------------------------------------------------
WORKBENCH_TABLE=cfins-qaworkbench

# --- S3 (execution artifacts) ------------------------------------------------
# Per-environment bucket for screenshots/video/traces (provision_s3.py creates
# it). Served via presigned URLs; nothing public.
ARTIFACTS_BUCKET=cfins-qaworkbench-local

# --- ECS (remote execution: mode run_now → ecs.run_task) ---------------------
# Only needed for the "Run Now" (remote/headless Fargate) path. Leave these
# BLANK to disable run_now — local CLI runs (qa nova run) still work, and the
# API returns a clear 400 if run_now is called. Values come from
# scripts/provision_ecs.py output (cluster + task def) and the default VPC
# (subnets + security group). The API's AWS identity needs ecs:RunTask +
# iam:PassRole on the runner roles.
#   * DEV:      RUNNER_TASK_DEFINITION can be the bare family (uses the latest
#               revision automatically).
#   * SAT/prod: PIN it to a revision, e.g. cfins-qaworkbench-runner:3, so a new
#               task-def registration can't silently change what prod runs.
ECS_CLUSTER=cfins-qaworkbench
RUNNER_TASK_DEFINITION=cfins-qaworkbench-runner
RUNNER_SUBNETS=subnet-xxxxxxxxxxxxxxxxx,subnet-yyyyyyyyyyyyyyyyy
RUNNER_SECURITY_GROUPS=sg-xxxxxxxxxxxxxxxxx
RUNNER_LAUNCH_TYPE=FARGATE
RUNNER_ASSIGN_PUBLIC_IP=ENABLED
# Default artifact capture for run_now: "screenshots" (per-step PNGs) or "full"
# (also uploads the HTML trace + video to S3). The execute request's optional
# `capture` field overrides this per run.
RUNNER_CAPTURE=screenshots

# --- Auth / JWT --------------------------------------------------------------
# Signing key for locally-minted HS256 tokens. Generate a random one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Keep it out of git; in prod load from Secrets Manager.
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ISSUER=cfins-qaworkbench
JWT_TTL_HOURS=8

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed UI origins (the Vite dev server).
CORS_ORIGINS=http://localhost:5173

# --- Cognito (SSO) -----------------------------------------------------------
# Leave blank to disable SSO (local login still works). No AWS credentials are
# needed for SSO login — tokens are validated via the public JWKS endpoint, and
# identity is fetched from the Managed-login /oauth2/userInfo endpoint.
COGNITO_USER_POOL_ID=us-east-1_y7VZjMb6N
COGNITO_CLIENT_ID=25ihduhnl3v8o4f4uuqjh41jkl
COGNITO_DOMAIN=https://us-east-1y7vzjmb6n.auth.us-east-1.amazoncognito.com